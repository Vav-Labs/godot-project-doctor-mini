{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Godot: Open Editor",
            "type": "process",
            "command": "${config:godotTools.editorPath.godot4}",
            "args": [
                "--path",
                "${workspaceFolder}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Godot: Run Project",
            "type": "process",
            "command": "${config:godotTools.editorPath.godot4}",
            "args": [
                "--path",
                "${workspaceFolder}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Godot: Validate Project Headless",
            "type": "process",
            "command": "${config:godotTools.editorPath.godot4}",
            "args": [
                "--headless",
                "--path",
                "${workspaceFolder}",
                "--quit"
            ],
            "problemMatcher": []
        },
        {
            "label": "Godot: Scan Project Headless",
            "type": "process",
            "command": "${config:godotTools.editorPath.godot4}",
            "args": [
                "--headless",
                "--path",
                "${workspaceFolder}",
                "--script",
                "res://addons/project_doctor_mini/tools/run_project_scan.gd"
            ],
            "problemMatcher": []
        }
    ]
}